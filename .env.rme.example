# ===========================================================================
# NovaCareEMR / Salam AI — environment template
# ===========================================================================
# Copy this file to web/.env.local (dev) atau web/.env.production.local (prod)
# Semua var diawali RME_ biar ga ketuker sama project lain di VPS yang sama.
# JANGAN commit file .env.* asli — cek .gitignore.
# ===========================================================================

# --- Database (Postgres 16, VPS 76.13.194.112) -----------------------------
# Dev database: novacare_rme_dev
# Prod database: novacare_rme_prod
# Role aplikasi: rme_app (NOSUPERUSER, akses hanya ke 2 db di atas)
RME_DATABASE_URL=postgresql://rme_app:PASSWORD_HERE@localhost:5432/novacare_rme_dev
RME_DATABASE_SSL=false

# --- App --------------------------------------------------------------------
RME_APP_ENV=development
RME_APP_URL=https://dev.rme.medinovatech.com
RME_ADMIN_URL=https://dashboard.rme.medinovatech.com

# --- Sessions & auth --------------------------------------------------------
# Generate with: openssl rand -base64 48
RME_SESSION_SECRET=REPLACE_WITH_RANDOM_48_BYTES
RME_ADMIN_SESSION_SECRET=REPLACE_WITH_RANDOM_48_BYTES

# --- Claude API reseller (Gold tier embedded assistant) --------------------
# Platform-owned Anthropic API key (Yanuar's own subscription).
# Dipakai untuk proxy chat assistant di web builder tenant.
# Scope: Puck block manipulation only. NO PHI access. Rate-limited per tenant.
RME_ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
RME_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Free credit allocation per tenant (turn-based, bukan token)
RME_CLAUDE_FREE_TURNS_PER_DAY=100
RME_CLAUDE_FREE_TURNS_PER_MONTH=500
RME_CLAUDE_TOPUP_ENABLED=true

# --- Notifications V1 ------------------------------------------------------
# Email via Resend
RME_RESEND_API_KEY=re_REPLACE_ME
RME_RESEND_FROM=noreply@rme.medinovatech.com

# Telegram bot (BotFather)
RME_TELEGRAM_BOT_TOKEN=REPLACE_ME
RME_TELEGRAM_BOT_USERNAME=SalamAI_bot

# --- SATUSEHAT (Kemenkes) --- ditaro di tenant config, bukan di env ------
# Placeholder dokumentasi doang — credential per-tenant disimpan encrypted
# di table tenants.satusehat_config (AES-256-GCM pakai RME_TENANT_KEK).
RME_TENANT_KEK=REPLACE_WITH_RANDOM_32_BYTES_HEX

# --- Logging ---------------------------------------------------------------
RME_LOG_LEVEL=info
